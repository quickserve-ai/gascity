# Mail — durable bidirectional delivery across CLI process boundaries
#
# This is the single cross-process, file-backed composition proof: city
# initialization wires mail to the bead store, separate gc processes observe
# the same messages, and human and configured-agent identities can address each
# other. Focused command tests own UI and validation semantics; mail.Provider
# conformance owns message state transitions.

env GC_BEADS=file
env GC_DOLT=skip
env GC_SESSION=fake

exec gc init $WORK/bright-lights
cd $WORK/bright-lights

! exec gc mail check mayor

# Human sends a durable message to the configured agent.
exec gc mail send mayor 'hey, are you still there?'
stdout 'Sent message gc-1 to mayor'

exec gc mail check mayor

exec gc mail inbox mayor
stdout 'human'
stdout 'hey, are you still there?'

# The configured agent can reply and a fresh human process sees it.
env GC_ALIAS=mayor
exec gc mail send human 'yes, still working'
stdout 'Sent message gc-2 to human'

env GC_ALIAS=
exec gc mail inbox
stdout 'mayor'
stdout 'yes, still working'
