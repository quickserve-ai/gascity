{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "x-gc-jsonl": {},
  "type": "object",
  "properties": {
    "schema_version": { "const": "1" },
    "ok": { "const": true },
    "command": { "const": "session history" },
    "agent": { "type": "string", "minLength": 1 },
    "work_dir": { "type": "string", "minLength": 1 },
    "total": { "type": "integer", "minimum": 0 },
    "conversations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "session_id": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "archived": { "type": "boolean" },
          "live": { "type": "boolean" },
          "live_bead": { "type": "string" },
          "title": { "type": "string" },
          "agent_name": { "type": "string" },
          "first_user": { "type": "string" },
          "started_at": { "type": "string" },
          "last_at": { "type": "string" },
          "size_bytes": { "type": "integer", "minimum": 0 }
        },
        "required": ["session_id", "path", "archived", "live", "last_at", "size_bytes"],
        "additionalProperties": true
      }
    }
  },
  "required": ["schema_version", "ok", "command", "agent", "work_dir", "total", "conversations"],
  "additionalProperties": true
}
